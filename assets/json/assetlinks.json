# 1. القفز لمجلد الهبوط وتحديث مخرجات الحماية
cd /srv/landing 2>/dev/null || cd ~/sahifati_backend_source
mkdir -p .well-known

# 2. حقن بصمة SHA-256 والمعرّف الفعلي للتطبيق داخل ملف assetlinks
